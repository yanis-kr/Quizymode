# Playwright screenshot credentials
# Copy to .env and fill in values before running: npx playwright test
TEST_USER_EMAIL=test-user@quizymode.com
TEST_USER_PASSWORD=your-password-here

# Public Cloudflare Turnstile site key for idea submission in the web app.
# Optional in local dev because the UI falls back to a development bypass token.
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key
