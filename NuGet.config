<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- nuget.org should remain to resolve public packages -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />

    <!--
      Add the private Aspire package feed that contains Aspire.AppHost.Sdk and related packages.
      Replace the URL below with the correct feed URL provided by Aspire or your organization.
      Example: https://pkgs.mycompany.com/nuget/v3/index.json
    -->
    <add key="Aspire" value="https://nuget.aspire.example/v3/index.json" />
  </packageSources>
</configuration>
