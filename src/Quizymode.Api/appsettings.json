{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.AspNetCore.Connections": "Warning",
      "Microsoft.AspNetCore.Routing": "Warning",
      "Microsoft.Extensions.Diagnostics.HealthChecks": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Database=quizymode;Username=postgres;Password=postgres"
  },
  "Seed": {
    "Path": "data/seed-dev"
  },
  "GitHubSeedSync": {
    "ApiBaseUrl": "https://api.github.com",
    "SourceFileIndexPath": "data/seed-source/_registry/source-file-index.json",
    "CollectionsPath": "data/seed-source/collections/public",
    "Token": "",
    "UserAgent": "Quizymode-SeedSync"
  },
  "IdeaAbuseProtection": {
    "CreateDailyLimit": 5,
    "ModerationTermsPath": "data/moderation/idea-moderation-terms.json"
  },
  "Turnstile": {
    "Enabled": false,
    "SecretKey": "",
    "VerifyEndpoint": "https://challenges.cloudflare.com/turnstile/v0/siteverify"
  },
  "Authentication": {
    "Cognito": {
      "Authority": "",
      "ClientId": "",
      "Audience": "",
      "Issuer": ""
    }
  },
  "GrafanaCloud": {
    "Enabled": false,
    "OtlpEndpoint": "",
    "LokiEndpoint": "",
    "OtlpInstanceId": "",
    "LokiInstanceId": "",
    "ApiKey": ""
  }
}
