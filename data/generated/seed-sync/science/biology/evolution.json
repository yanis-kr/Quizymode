      "navigationKeyword2": "evolution",
      "question": "What is convergent evolution?",
      "correctAnswer": "Similar traits evolve independently in different lineages",
      "incorrectAnswers": [
        "Always homology",
        "Always genetic drift",
        "Always hybridization"
      ],
      "explanation": "Wings in birds and bats are a classic analogy example.",
