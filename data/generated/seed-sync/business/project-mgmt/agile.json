      "question": "When might waterfall still be reasonable?",
      "correctAnswer": "Highly regulated, fixed-scope environments where change is costly and well-specified upfront.",
      "incorrectAnswers": [
        "Never, in any context.",
        "Always for every software project.",
        "Only for hobbies."
      ],
      "explanation": "Choose lifecycle based on uncertainty and constraints.",
      "keywords": [
        "waterfall",
        "lifecycle"
      ],
      "source": "https://www.pmi.org/learning/library/agile-vs-waterfall-7118"
    },
