      "question": "What is a process bottleneck?",
      "correctAnswer": "A step where work piles up because capacity or throughput is constrained.",
      "incorrectAnswers": [
        "Any step with zero employees.",
        "A marketing slogan.",
        "A type of bank account."
      ],
      "explanation": "Bottlenecks limit end-to-end flow performance.",
      "keywords": [
        "bottleneck",
        "throughput"
      ],
      "source": "https://en.wikipedia.org/wiki/Bottleneck_(production)"
    },
