    "question": "What is the critical path?",
    "correctAnswer": "The longest sequence of dependent tasks that determines the shortest possible project duration.",
    "incorrectAnswers": [
      "Any task you like.",
      "Tasks with zero risk.",
      "Only procurement tasks."
    ],
    "explanation": "Slipping critical path tasks delays the project.",
