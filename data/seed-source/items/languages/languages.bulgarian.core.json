    "question": "How do you say 'hello' in Bulgarian?",
    "correctAnswer": "Здравейте (Zdraveyte) — formal / Здравей (Zdravey) — informal",
    "incorrectAnswers": [
      "Довиждане (Dovizhdane)",
      "Благодаря (Blagodarya)",
      "Моля (Molya)"
    ],
    "explanation": "'Zdraveyte' is formal; 'zdravey' is informal. The -te suffix marks formal/plural in Bulgarian.",
    "keywords": [
      "freq-100",
      "situation-greetings",
      "cefr-a1"
    ],
    "source": "https://www.omniglot.com/language/phrases/bulgarian.htm"
  },
