  {
    "itemId": "7614f5ae-7ed5-4509-8df9-fceab6117719",
    "category": "languages",
    "navigationKeyword1": "bulgarian",
    "navigationKeyword2": "core",
    "question": "In Bulgarian, a head nod usually means what?",
    "correctAnswer": "no (unlike most countries)",
    "incorrectAnswers": [
      "yes",
      "maybe",
      "goodbye"
    ],
    "explanation": "In Bulgaria, a vertical head nod traditionally means NO and a horizontal shake means YES — opposite to most cultures. Awareness is essential for travellers.",
    "keywords": [
      "freq-100",
      "cefr-a1"
    ],
    "source": "https://www.omniglot.com/language/phrases/bulgarian.htm"
  },
