    "question": "How do you say 'thank you' in Romanian?",
    "correctAnswer": "{{ro-RO|Mulțumesc||}}",
    "incorrectAnswers": [
      "{{ro-RO|Vă rog||}}",
      "{{ro-RO|Scuzați-mă||}}",
      "{{ro-RO|Bună ziua||}}"
    ],
    "explanation": "'Mulțumesc' is the standard thank you. 'Mulțumesc frumos' = thank you very much (literally 'thank you beautifully').",
    "keywords": [
      "freq-100",
      "situation-greetings",
      "cefr-a1"
    ],
    "source": "https://www.omniglot.com/language/phrases/romanian.htm"
  },
  {
