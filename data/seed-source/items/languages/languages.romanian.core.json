    "question": "How do you say 'please' in Romanian?",
    "correctAnswer": "{{ro-RO|Vă rog||}} (formal) / {{ro-RO|Te rog||}} (informal)",
    "incorrectAnswers": [
      "{{ro-RO|Mulțumesc||}}",
      "{{ro-RO|Scuzați-mă||}}",
      "{{ro-RO|Da||}}"
    ],
    "explanation": "'Vă rog' is formal, 'te rog' informal. Both mean 'I beg you' — the polite please.",
    "keywords": [
      "freq-100",
      "cefr-a1"
    ],
    "source": "https://www.omniglot.com/language/phrases/romanian.htm"
  },
  {
