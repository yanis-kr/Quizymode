    "question": "How do you say 'hello' in Romanian?",
    "correctAnswer": "{{ro-RO|Bună ziua||}} (formal) / {{ro-RO|Salut||}} (informal)",
    "incorrectAnswers": [
      "{{ro-RO|La revedere||}}",
      "{{ro-RO|Mulțumesc||}}",
      "{{ro-RO|Vă rog||}}"
    ],
    "explanation": "'Bună ziua' = good day (formal). 'Salut' is casual hello. 'Bună' alone works in neutral contexts.",
    "keywords": [
      "freq-100",
      "situation-greetings",
      "cefr-a1"
    ],
    "source": "https://www.omniglot.com/language/phrases/romanian.htm"
  },
