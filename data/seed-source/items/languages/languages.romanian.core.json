    "question": "How do you say 'my name is' in Romanian?",
    "correctAnswer": "{{ro-RO|Mă numesc...||}}",
    "incorrectAnswers": [
      "{{ro-RO|Locuiesc în...||}}",
      "{{ro-RO|Sunt din...||}}",
      "{{ro-RO|Îmi place...||}}"
    ],
    "explanation": "'Mă numesc [name]' — 'I name myself [name]' — the standard introduction. Romanian origin is Latin 'nominare'.",
    "keywords": [
      "freq-100",
      "situation-intro",
      "cefr-a1"
    ],
    "source": "https://www.omniglot.com/language/phrases/romanian.htm"
