    "question": "How do you count 1, 2, 3 in Romanian?",
    "correctAnswer": "{{ro-RO|unu, doi, trei||}}",
    "incorrectAnswers": [
      "{{ro-RO|un, deux, trois||}}",
      "{{ro-RO|uno, dos, tres||}}",
      "{{ro-RO|un, dwa, trzy||}}"
    ],
    "explanation": "Romanian numbers: unu (1), doi (2), trei (3). Very similar to other Romance languages.",
    "keywords": [
      "freq-100",
      "cefr-a1"
    ],
    "source": "https://www.omniglot.com/language/numbers/romanian.htm"
