      "{{ro-RO|pâine||}}",
      "{{ro-RO|lapte||}}",
      "{{ro-RO|vin||}}"
    ],
    "explanation": "'Apă' means water (from Latin 'aqua'). 'Pâine' = bread, 'lapte' = milk, 'vin' = wine.",
