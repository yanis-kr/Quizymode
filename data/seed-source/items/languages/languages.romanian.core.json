    "navigationKeyword1": "romanian",
    "navigationKeyword2": "core",
    "question": "How do you say 'yes' and 'no' in Romanian?",
    "correctAnswer": "{{ro-RO|Da||}} / {{ro-RO|Nu||}}",
    "incorrectAnswers": [
      "{{ro-RO|Sì||}} / {{ro-RO|No||}}",
      "Oui / Non",
      "Так / Ні"
    ],
    "explanation": "'Da' = yes, 'Nu' = no. Romanian is a Romance language so many words resemble Italian/Spanish.",
    "keywords": [
      "freq-100",
      "cefr-a1"
    ],
    "source": "https://www.omniglot.com/language/phrases/romanian.htm"
  },
