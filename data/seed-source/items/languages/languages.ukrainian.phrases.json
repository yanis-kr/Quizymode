    "question": "How do you ask 'Where is the bathroom?' in Ukrainian?",
    "correctAnswer": "{{uk-UA|Де туалет?|De tualet?|}}",
    "incorrectAnswers": [
      "{{uk-UA|Що таке туалет?|Shcho take tualet?|}}",
      "{{uk-UA|Коли відкрито?|Koly vidkryto?|}}",
      "{{uk-UA|Скільки коштує?|Skilky koshtuye?|}}"
    ],
    "explanation": "'De' means 'where'. 'De tualet?' is the most practical travel phrase.",
