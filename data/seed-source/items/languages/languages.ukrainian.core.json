    "question": "How do you say 'hello' in Ukrainian?",
    "correctAnswer": "{{uk-UA|Привіт|Pryvit|}}",
    "incorrectAnswers": [
      "{{uk-UA|До побачення|Do pobachennya|}}",
      "{{uk-UA|Дякую|Dyakuyu|}}",
      "{{uk-UA|Будь ласка|Bud laska|}}"
    ],
    "explanation": "'Pryvit' is the casual hello. Formal: 'Dobroho dnya' (good day).",
    "keywords": [
      "freq-100",
      "situation-greetings",
      "cefr-a1"
    ],
    "source": "https://www.omniglot.com/language/phrases/ukrainian.htm"
