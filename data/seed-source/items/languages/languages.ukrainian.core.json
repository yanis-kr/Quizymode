    "question": "How do you count 1, 2, 3 in Ukrainian?",
    "correctAnswer": "{{uk-UA|один, два, три|odyn, dva, try|}}",
    "incorrectAnswers": [
      "un, dwa, trzy",
      "viens, divi, trīs",
      "{{uk-UA|один, два, тры|Russian|}}"
    ],
    "explanation": "Ukrainian: odyn (1), dva (2), try (3). Compare to Russian odin/dva/tri — similar but distinct.",
    "keywords": [
      "freq-100",
      "cefr-a1"
    ],
    "source": "https://www.omniglot.com/language/numbers/ukrainian.htm"
