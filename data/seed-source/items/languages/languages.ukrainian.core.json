    "question": "How do you say 'thank you' in Ukrainian?",
    "correctAnswer": "{{uk-UA|Дякую|Dyakuyu|}}",
    "incorrectAnswers": [
      "{{uk-UA|Будь ласка|Bud laska|}}",
