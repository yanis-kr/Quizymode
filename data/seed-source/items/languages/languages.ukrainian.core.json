    "navigationKeyword1": "ukrainian",
    "navigationKeyword2": "core",
    "question": "How do you say 'yes' and 'no' in Ukrainian?",
    "correctAnswer": "{{uk-UA|Так|Tak|}} / {{uk-UA|Ні|Ni|}}",
    "incorrectAnswers": [
      "Да / Нет",
      "Oui / Non",
      "Jā / Nē"
    ],
    "explanation": "'Tak' is yes, 'Ni' is no. Note: Ukrainian 'Tak' and Russian 'Da' differ.",
    "keywords": [
      "freq-100",
      "cefr-a1"
    ],
    "source": "https://www.omniglot.com/language/phrases/ukrainian.htm"
  },
  {
