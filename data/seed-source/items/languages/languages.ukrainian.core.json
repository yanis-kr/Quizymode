    "question": "How do you say 'goodbye' in Ukrainian?",
    "correctAnswer": "{{uk-UA|До побачення|Do pobachennya|}}",
    "incorrectAnswers": [
      "{{uk-UA|Привіт|Pryvit|}}",
      "{{uk-UA|Дякую|Dyakuyu|}}",
      "{{uk-UA|Вибачте|Vybachte|}}"
    ],
    "explanation": "'Do pobachennya' — 'until we see each other' — is the formal goodbye. Informal: 'Buvay'.",
    "keywords": [
      "freq-100",
      "situation-greetings",
      "cefr-a1"
    ],
    "source": "https://www.omniglot.com/language/phrases/ukrainian.htm"
