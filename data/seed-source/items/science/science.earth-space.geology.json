    "navigationKeyword2": "geology",
    "question": "What is igneous rock?",
    "correctAnswer": "Formed from cooled magma or lava",
    "incorrectAnswers": [
      "From compacted shells only",
      "From heat/pressure on existing rock",
      "From evaporation only"
    ],
    "explanation": "Basalt and granite are examples.",
    "keywords": [
      "igneous",
      "rocks"
    ],
    "source": "https://www.usgs.gov/schools/rock-cycle"
  },
  {
    "itemId": "808519a9-eeee-48ce-81f7-f09dc13c990a",
    "category": "science",
    "navigationKeyword1": "earth-space",
    "navigationKeyword2": "geology",
    "question": "What is sedimentary rock?",
    "correctAnswer": "Formed from deposited and lithified sediments",
    "incorrectAnswers": [
      "From magma cooling",
      "From pure metamorphism only",
      "From lightning"
    ],
    "explanation": "Often preserves fossils.",
    "keywords": [
      "sedimentary",
      "rocks"
    ],
    "source": "https://www.usgs.gov/schools/rock-cycle"
  },
  {
    "itemId": "965f6409-7c2b-4d3f-b21b-e128a89c6e8d",
    "category": "science",
    "navigationKeyword1": "earth-space",
    "navigationKeyword2": "geology",
    "question": "What is metamorphic rock?",
    "correctAnswer": "Formed by heat and pressure transforming existing rock",
    "incorrectAnswers": [
      "From lava only",
      "From wind only",
      "From photosynthesis"
    ],
    "explanation": "Examples: marble, schist.",
    "keywords": [
      "metamorphic",
      "rocks"
    ],
    "source": "https://www.usgs.gov/schools/rock-cycle"
  },
