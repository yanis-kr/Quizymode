    "question": "What is an ecosystem?",
    "correctAnswer": "Biotic community plus its abiotic environment",
    "incorrectAnswers": [
      "Only animals",
      "Only soil",
      "Only the atmosphere"
    ],
    "explanation": "Energy and nutrients flow through ecosystems.",
    "keywords": [
      "ecosystem",
      "ecology"
    ],
    "source": "https://www.nature.com/scitable/knowledge/library/ecology-102"
